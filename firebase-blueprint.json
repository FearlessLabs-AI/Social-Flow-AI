{
  "entities": {
    "GeneratedContent": {
      "title": "Generated Content",
      "description": "Content generated by AI for social media",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "platform": { "type": "string" },
        "tone": { "type": "string" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "text", "platform", "tone", "prompt", "timestamp", "userId"]
    }
  },
  "firestore": {
    "generated_content/{contentId}": {
      "schema": "GeneratedContent",
      "description": "User generated content history"
    }
  }
}
