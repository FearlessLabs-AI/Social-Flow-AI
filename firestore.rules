rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidGeneratedContent(data) {
      return data.keys().hasAll(['id', 'text', 'platform', 'tone', 'prompt', 'timestamp', 'userId'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.text is string && data.text.size() <= 10000
        && data.platform is string && data.platform.size() <= 20
        && data.tone is string && data.tone.size() <= 20
        && data.prompt is string && data.prompt.size() <= 1000
        && data.timestamp is number
        && data.userId == request.auth.uid;
    }

    // --- Collections ---
    match /generated_content/{contentId} {
      allow create: if isSignedIn() 
        && isValidId(contentId) 
        && isValidGeneratedContent(incoming());

      allow get: if isSignedIn() && isOwner(existing().userId);
      
      allow list: if isSignedIn() 
        && resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() && isOwner(existing().userId);

      // Updates are not allowed for this app's logic (content is immutable history)
      allow update: if false;
    }
  }
}
